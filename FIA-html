<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jeu du Serpent - Snake Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: 'Arial', sans-serif;
        }

        .container {
            text-align: center;
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(4px);
        }

        h1 {
            color: #fff;
            margin-bottom: 20px;
            font-size: 2.5em;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }

        canvas {
            display: block;
            background-color: #1a1a2e;
            border: 3px solid #00ff88;
            margin: 20px auto;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.5);
        }

        .info {
            display: flex;
            justify-content: space-around;
            margin: 20px 0;
            color: #fff;
            font-size: 1.2em;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
        }

        .info span {
            font-weight: bold;
            color: #00ff88;
        }

        .controls {
            margin: 20px 0;
            color: #fff;
            font-size: 0.95em;
        }

        button {
            background: #00ff88;
            border: none;
            padding: 12px 30px;
            font-size: 1.1em;
            border-radius: 8px;
            cursor: pointer;
            margin: 10px 5px;
            font-weight: bold;
            color: #1a1a2e;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 255, 136, 0.3);
        }

        button:hover {
            background: #00dd77;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.5);
        }

        .game-over {
            display: none;
            color: #ff4444;
            font-size: 1.5em;
            margin: 15px 0;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🐍 Jeu du Serpent</h1>
        <canvas id="gameCanvas" width="400" height="400"></canvas>
        
        <div class="info">
            <div>Score: <span id="score">0</span></div>
            <div>Meilleur: <span id="highScore">0</span></div>
        </div>

        <div class="game-over" id="gameOverMessage">Game Over! 💥</div>

        <div class="controls">
            <p><strong>Commandes:</strong> ⬅️ ➡️ ⬆️ ⬇️ ou ZQSD</p>
        </div>

        <div>
            <button onclick="startGame()">Démarrer</button>
            <button onclick="pauseGame()">Pause</button>
            <button onclick="resetGame()">Réinitialiser</button>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const gridSize = 20;
        const tileCount = canvas.width / gridSize;

        let snake = [{x: 10, y: 10}];
        let food = {x: 15, y: 15};
        let score = 0;
        let highScore = localStorage.getItem('snakeHighScore') || 0;
        let direction = {x: 1, y: 0};
        let nextDirection = {x: 1, y: 0};
        let gameRunning = false;
        let gamePaused = false;
        let gameOver = false;

        document.getElementById('highScore').textContent = highScore;

        function generateFood() {
            let newFood;
            let isOnSnake;
            do {
                newFood = {
                    x: Math.floor(Math.random() * tileCount),
                    y: Math.floor(Math.random() * tileCount)
                };
                isOnSnake = snake.some(segment => segment.x === newFood.x && segment.y === newFood.y);
            } while (isOnSnake);
            return newFood;
        }

        function draw() {
            ctx.fillStyle = '#1a1a2e';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Nourriture
            ctx.fillStyle = '#ff4444';
            ctx.beginPath();
            ctx.arc(food.x * gridSize + gridSize / 2, food.y * gridSize + gridSize / 2, gridSize / 2 - 2, 0, Math.PI * 2);
            ctx.fill();

            // Serpent
            snake.forEach((segment, index) => {
                ctx.fillStyle = index === 0 ? '#00ff88' : '#00cc66';
                ctx.fillRect(segment.x * gridSize + 1, segment.y * gridSize + 1, gridSize - 2, gridSize - 2);
            });
        }

        function update() {
            if (gameOver || !gameRunning || gamePaused) return;

            direction = nextDirection;
            const head = snake[0];
            const newHead = {
                x: (head.x + direction.x + tileCount) % tileCount,
                y: (head.y + direction.y + tileCount) % tileCount
            };

            if (snake.some(segment => segment.x === newHead.x && segment.y === newHead.y)) {
                endGame();
                return;
            }

            snake.unshift(newHead);

            if (newHead.x === food.x && newHead.y === food.y) {
                score += 10;
                document.getElementById('score').textContent = score;
                food = generateFood();
            } else {
                snake.pop();
            }
        }

        document.addEventListener('keydown', (e) => {
            const key = e.key.toLowerCase();
            if (key === 'arrowup' || key === 'w' || key === 'z') {
                if (direction.y === 0) nextDirection = {x: 0, y: -1};
            } else if (key === 'arrowdown' || key === 's') {
                if (direction.y === 0) nextDirection = {x: 0, y: 1};
            } else if (key === 'arrowleft' || key === 'a' || key === 'q') {
                if (direction.x === 0) nextDirection = {x: -1, y: 0};
            } else if (key === 'arrowright' || key === 'd') {
                if (direction.x === 0) nextDirection = {x: 1, y: 0};
            }
        });

        function startGame() {
            if (gameRunning) return;
            gameRunning = true;
            gamePaused = false;
            gameOver = false;
            document.getElementById('gameOverMessage').style.display = 'none';
            setInterval(() => { update(); draw(); }, 100);
        }

        function pauseGame() {
            if (!gameRunning) return;
            gamePaused = !gamePaused;
        }

        function resetGame() {
            snake = [{x: 10, y: 10}];
            food = generateFood();
            score = 0;
            gameRunning = false;
            document.getElementById('score').textContent = '0';
            draw();
        }

        function endGame() {
            gameRunning = false;
            gameOver = true;
            document.getElementById('gameOverMessage').style.display = 'block';
            if (score > highScore) {
                highScore = score;
                localStorage.setItem('snakeHighScore', highScore);
                document.getElementById('highScore').textContent = highScore;
            }
        }

        draw();
    </script>
</body>
</html>
